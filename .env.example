# Required for download-history, stats, merge, sync, etc. — not used for `scan` or `completions`.
DATABASE_URL=sqlite://db.sqlite?mode=rwc

# Not used on mac
BLE_INTERFACE="hci1 (usb:Something)"

WHOOP=00:00:00:00:00:00
RUST_LOG=info
DEBUG_PACKETS=true

# Studio (`live-server`): bind address (default 127.0.0.1). Use 0.0.0.0 only with TLS/auth in front.
# OPENWHOOP_STUDIO_BIND=0.0.0.0
# Comma-separated browser origins allowed to call /api/* (CORS). Example: GitHub Pages site.
# OPENWHOOP_CORS_ORIGIN=https://yourname.github.io
# Agent CLI: URL of the live-server (default http://127.0.0.1:3848)
# OPENWHOOP_STUDIO_URL=http://127.0.0.1:3848